{
  "$schema": "vscode://schemas/color-theme",
  "name": "boring light blue",
  "type": "light",
  "include": "./light-base.json",
  "colors": {
    "editor.foreground": "#202224"
  },
  "tokenColors": [
    {
      "name": "Control flow",
      "scope": [
        "keyword.control",
        // "keyword.operator.logical",
        "storage.type.function",
        "keyword.function",
        "keyword.type",
        "keyword.var",
        "keyword.struct",
        "storage.type.class.python"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Class+Function definition",
      "scope": [
        "entity.name.function.go",
        "entity.name.function.python",
        "entity.name.type.class",
        "entity.function"
      ],
      "settings": {
        "foreground": "#0550ae"
      }
    },
    {
      "name": "Strings",
      "scope": ["string", "entity.name.import.go", "punctuation.definition.string"],
      "settings": {
        "foreground": "#0a3069"
      }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric", "constant.language", "keyword.other.unit.hexadecimal"],
      "settings": {
        "foreground": "#2b5588"
      }
    },
    {
      "name": "Comments",
      "scope": ["comment", "string.quoted.docstring.multi"],
      "settings": {
        "foreground": "#888"
      }
    },
    {
      "name": "JSON Key",
      "scope": ["support.type.property-name.json", "punctuation.support.type.property-name"],
      "settings": {
        "foreground": "#24292E"
      }
    }
  ]
}
